{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "noImplicitReturns": true,

    "paths": {
      "*": ["./types/*"]
    },

    "types": ["*"],

    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
